{
  "name": "sonarqube-issues-exporter",
  "version": "3.2.6",
  "description": "Export SonarQube issues to beautiful HTML reports — interactive dashboards, quality gate status, dark/light themes, zero-config CLI.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "sonarqube-exporter": "dist/cli.js",
    "sq-exporter": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && eslint src tests",
    "lint:eslint": "eslint src tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm lint && pnpm format:check && pnpm test"
  },
  "keywords": [
    "sonarqube",
    "sonarcloud",
    "issues",
    "exporter",
    "html",
    "report",
    "typescript",
    "cli",
    "code-quality",
    "static-analysis",
    "vulnerability",
    "bugs",
    "code-smell",
    "dashboard",
    "quality-gate"
  ],
  "author": "The-Lone-Druid (https://github.com/The-Lone-Druid)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Lone-Druid/sonarqube-issues-exporter.git"
  },
  "bugs": {
    "url": "https://github.com/The-Lone-Druid/sonarqube-issues-exporter/issues"
  },
  "homepage": "https://github.com/The-Lone-Druid/sonarqube-issues-exporter#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
