{
  "name": "sonarqube-issues-exporter",
  "version": "5.0.1",
  "description": "Run a local SonarQube dashboard on your machine — live issues, quality gate, hotspots, coverage across projects/branches, with PDF export. No more logging into the dashboard or SSHing to the VM.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "sonarqube-exporter": "dist/cli.js",
    "sq-exporter": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:web && pnpm build:server",
    "clean": "rm -rf dist",
    "build:web": "vite build",
    "build:server": "tsup",
    "dev": "concurrently -n web,server -c cyan,magenta \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:web": "vite --open",
    "dev:server": "tsx watch src/cli.ts serve --no-open --verbose",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && tsc -p tsconfig.web.json --noEmit && eslint src tests",
    "lint:eslint": "eslint src tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm lint && pnpm test && node scripts/check-dist.mjs"
  },
  "keywords": [
    "sonarqube",
    "sonarcloud",
    "dashboard",
    "code-quality",
    "static-analysis",
    "quality-gate",
    "security-hotspots",
    "coverage",
    "pdf-report",
    "cli",
    "local",
    "typescript"
  ],
  "author": "The-Lone-Druid (https://github.com/The-Lone-Druid)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Lone-Druid/sonarqube-issues-exporter.git"
  },
  "bugs": {
    "url": "https://github.com/The-Lone-Druid/sonarqube-issues-exporter/issues"
  },
  "homepage": "https://github.com/The-Lone-Druid/sonarqube-issues-exporter#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "sonarqube-scanner": "^4.3.6",
    "commander": "^12.1.0",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "hono": "^4.6.0",
    "open": "^10.1.0"
  },
  "optionalDependencies": {
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "dompurify": "^3.4.7",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "knip": "^6.15.0",
    "lint-staged": "^16.4.0",
    "lucide-react": "^0.460.0",
    "prettier": "^3.8.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
